// schema.prisma

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== ENUMS =====
enum UserRole {
  SUPER_ADMIN
  SAAS_ADMIN
  STANDARD_USER
}

enum UserOrganizationRole {
  ORG_ADMIN
  EMPLOYEE
}

enum UserOrganizationPermissionProfile {
  FULL_SERVICE
  FRONT_DESK
  SALES_ONLY
  OPERATOR
  VIEW_ONLY
}

enum ExtraPricingType {
  PER_UNIT
  FIXED
}

enum ServiceOrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  PAID
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  CONVERTED
  CANCELLED
  EXPIRED
}

enum ServiceOrderFlowType {
  WALK_IN
  SCHEDULED
}

enum ServiceOrderItemType {
  SERVICE
  EXTRA
  ADJUSTMENT
}

enum QuoteItemType {
  SERVICE
  EXTRA
  ADJUSTMENT
}

// ===== MODELOS =====

model Organization {
  id              String   @id @default(cuid())
  name            String
  defaultTimezone String   @default("UTC")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  memberships UserOrganization[]
  clients     Client[]            @relation("OrganizationClients")
  quoteConfig OrganizationConfig?
  quotes      Quote[]
  serviceOrders ServiceOrder[]
}

model User {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  phone       String
  countryCode String
  email       String   @unique
  alias       String?
  timezone    String?
  role        UserRole
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Login codes asociados
  loginCodes  LoginCode[]
  memberships UserOrganization[]
  createdQuotes Quote[] @relation("QuotesCreatedBy")
  createdServiceOrders ServiceOrder[] @relation("ServiceOrdersCreatedBy")
  assignedServiceOrders ServiceOrder[] @relation("ServiceOrdersAssignedTo")
}

model Client {
  id    String  @id @default(cuid())
  name  String
  phone String
  email String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con organización
  organization   Organization? @relation("OrganizationClients", fields: [organizationId], references: [id])
  organizationId String?
  quotes         Quote[]
  serviceOrders  ServiceOrder[]
}

model LoginCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relación con usuario opcional
  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model UserOrganization {
  id             String               @id @default(cuid())
  userId         String
  organizationId String
  role           UserOrganizationRole @default(EMPLOYEE)
  permissionProfile UserOrganizationPermissionProfile @default(FULL_SERVICE)
  createdAt      DateTime             @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model OrganizationConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  businessName   String
  businessType   String   @default("general")
  logoUrl        String?
  quoteTemplate  String   @default("modern")
  primaryColor   String   @default("#1f2937")
  secondaryColor String   @default("#fffaf4")
  currency       String   @default("MXN")
  language       String   @default("es-MX")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  serviceCategories ServiceCategory[]
  extraOptions      ExtraOption[]
  businessRules     BusinessRules?
  uiConfig          UIConfig?

  @@index([organizationId])
}

model ServiceCategory {
  id                   String   @id @default(cuid())
  organizationConfigId String
  name                 String
  description          String?
  multiSelect          Boolean  @default(false)
  sortOrder            Int      @default(0)
  metadata             Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organizationConfig OrganizationConfig @relation(fields: [organizationConfigId], references: [id], onDelete: Cascade)
  options            ServiceOption[]

  @@index([organizationConfigId, sortOrder])
}

model ServiceOption {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  price       Int
  sortOrder   Int      @default(0)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, sortOrder])
}

model ExtraOption {
  id                   String           @id @default(cuid())
  organizationConfigId String
  name                 String
  description          String?
  price                Int
  pricingType          ExtraPricingType @default(PER_UNIT)
  includedQuantity     Int              @default(0)
  sortOrder            Int              @default(0)
  metadata             Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  organizationConfig OrganizationConfig @relation(fields: [organizationConfigId], references: [id], onDelete: Cascade)

  @@index([organizationConfigId, sortOrder])
}

model BusinessRules {
  id                    String   @id @default(cuid())
  organizationConfigId  String   @unique
  maxSelectedCategories Int?
  maxQuantityPerExtra   Int?
  maxTotalSelections    Int?
  extraPricingRules     Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organizationConfig OrganizationConfig @relation(fields: [organizationConfigId], references: [id], onDelete: Cascade)
}

model UIConfig {
  id                   String   @id @default(cuid())
  organizationConfigId String   @unique
  titles               Json?
  texts                Json?
  labels               Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organizationConfig OrganizationConfig @relation(fields: [organizationConfigId], references: [id], onDelete: Cascade)
}

model ServiceOrder {
  id              String               @id @default(cuid())
  organizationId  String
  clientId        String?
  sourceQuoteId   String?
  createdByUserId String?
  assignedToUserId String?
  status          ServiceOrderStatus   @default(DRAFT)
  flowType        ServiceOrderFlowType @default(WALK_IN)
  customerName    String?
  customerPhone   String?
  notes           String?
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  paidAt          DateTime?
  subtotal        Int                  @default(0)
  total           Int                  @default(0)
  currency        String               @default("MXN")
  source          String               @default("quote_calculator_v2")
  snapshot        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  sourceQuote  Quote?       @relation("ServiceOrderSourceQuote", fields: [sourceQuoteId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("ServiceOrdersCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo   User?        @relation("ServiceOrdersAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  items        ServiceOrderItem[]

  @@index([organizationId, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, scheduledFor])
  @@index([clientId])
  @@index([assignedToUserId])
  @@index([sourceQuoteId])
}

model ServiceOrderItem {
  id             String               @id @default(cuid())
  serviceOrderId String
  itemType       ServiceOrderItemType
  label          String
  description    String?
  quantity       Int                  @default(1)
  unitPrice      Int
  total          Int
  sortOrder      Int                  @default(0)
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId, sortOrder])
}

model Quote {
  id               String               @id @default(cuid())
  organizationId   String
  clientId         String?
  createdByUserId  String?
  status           QuoteStatus          @default(DRAFT)
  flowType         ServiceOrderFlowType @default(WALK_IN)
  customerName     String?
  customerPhone    String?
  notes            String?
  scheduledFor     DateTime?
  acceptedAt       DateTime?
  convertedAt      DateTime?
  subtotal         Int                  @default(0)
  total            Int                  @default(0)
  currency         String               @default("MXN")
  source           String               @default("quote_calculator_v2")
  snapshot         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy      User?             @relation("QuotesCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items          QuoteItem[]
  serviceOrders  ServiceOrder[]    @relation("ServiceOrderSourceQuote")

  @@index([organizationId, createdAt])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, scheduledFor])
  @@index([clientId])
}

model QuoteItem {
  id        String        @id @default(cuid())
  quoteId    String
  itemType  QuoteItemType
  label     String
  description String?
  quantity  Int           @default(1)
  unitPrice Int
  total     Int
  sortOrder Int           @default(0)
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId, sortOrder])
}
